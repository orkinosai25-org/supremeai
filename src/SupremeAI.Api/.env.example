# SupremeAI API – Environment Variables
# Copy this file to .env and fill in your keys.
#
#   cp .env.example .env
#
# Then run:   dotnet run
# Or use the one-file quickstart from the repo root:   ./quickstart.sh

# ── Azure OpenAI (GPT-4o, GPT-4o-mini, o1-preview, DALL-E 3) ─────────────────
# Get from: Azure Portal → Your Azure OpenAI resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# ── Anthropic (Claude 3.5 Sonnet) ─────────────────────────────────────────────
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# ── Google (Gemini 1.5 Pro) ───────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=

# ── xAI (Grok-2) ─────────────────────────────────────────────────────────────
# Get from: https://console.x.ai
XAI_GROK_API_KEY=

# ── Azure AI Foundry – Serverless Endpoints ───────────────────────────────────
# These are filled automatically if you run scripts/azure/setup.sh
# Or set them manually from: Azure AI Foundry Studio → Deployments
PHI_35_MINI_ENDPOINT=
PHI_35_MINI_API_KEY=
PHI_3_MEDIUM_ENDPOINT=
PHI_3_MEDIUM_API_KEY=
LLAMA_31_70B_ENDPOINT=
LLAMA_31_70B_API_KEY=
MISTRAL_LARGE_ENDPOINT=
MISTRAL_LARGE_API_KEY=
COMMAND_R_PLUS_ENDPOINT=
COMMAND_R_PLUS_API_KEY=
JAIS_30B_ENDPOINT=
JAIS_30B_API_KEY=

# ── Azure Key Vault (optional – loads all secrets automatically) ──────────────
# If set, all the above keys are loaded from Key Vault instead of env vars.
# Get the URI from: Azure Portal → Key Vault → Overview → Vault URI
AZURE_KEYVAULT_URI=
