{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  // ── Azure Key Vault (recommended for production) ──────────────────────────
  // Set AZURE_KEYVAULT_URI as an App Service environment variable (or in .env)
  // to load all secrets from Key Vault instead of individual env vars.
  // The App Service managed identity must have "Key Vault Secrets User" role.
  "AzureKeyVaultUri": "",

  // ── CORS ──────────────────────────────────────────────────────────────────
  // Replace with your production frontend origin(s).
  "AllowedOrigins": [
    "https://your-app.azurewebsites.net"
  ]

  // ── Model provider environment variables ──────────────────────────────────
  // Set these as Azure App Service environment variables (Configuration blade),
  // NOT as values in this file.  The names below are what the code reads via
  // IConfiguration — use them exactly as shown.
  //
  //   Azure OpenAI (GPT-4o, GPT-4o-mini, o1-preview, DALL-E 3)
  //     AZURE_OPENAI_ENDPOINT  = https://<resource>.openai.azure.com/
  //     AZURE_OPENAI_API_KEY   = <key from Azure Portal>
  //
  //   Anthropic (Claude 3.5 Sonnet)
  //     ANTHROPIC_API_KEY      = sk-ant-...
  //
  //   Google (Gemini 1.5 Pro)
  //     GOOGLE_GEMINI_API_KEY  = AIza...
  //
  //   xAI (Grok-2)
  //     XAI_GROK_API_KEY       = xai-...
  //
  //   Azure AI Foundry – Serverless Endpoints (one per model)
  //     LLAMA_31_70B_ENDPOINT       = https://...inference.ai.azure.com/
  //     LLAMA_31_70B_API_KEY        = <key>
  //     MISTRAL_LARGE_ENDPOINT      = https://...inference.ai.azure.com/
  //     MISTRAL_LARGE_API_KEY       = <key>
  //     PHI_35_MINI_ENDPOINT        = https://...inference.ai.azure.com/
  //     PHI_35_MINI_API_KEY         = <key>
  //     PHI_3_MEDIUM_ENDPOINT       = https://...inference.ai.azure.com/
  //     PHI_3_MEDIUM_API_KEY        = <key>
  //     COMMAND_R_PLUS_ENDPOINT     = https://...inference.ai.azure.com/
  //     COMMAND_R_PLUS_API_KEY      = <key>
  //     JAIS_30B_ENDPOINT           = https://...inference.ai.azure.com/
  //     JAIS_30B_API_KEY            = <key>
  //
  //   Optional: expose Swagger UI in non-Development environments
  //     ENABLE_SWAGGER             = true
  //
  // To verify which providers are active after deploying, call:
  //     GET /api/ai/diagnostics
}
