    private async void SubmitCreativePrompt()
    {
        if (string.IsNullOrWhiteSpace(CreativePrompt)) return;
        var prompt = CreativePrompt.Trim();
        CreativePrompt = "";
        var models = ModelCatalogue.ChatModels.Where(m => SelectedIds.Contains(m.Id) && !m.ComingSoon).Take(2).ToList();
        CreativeResponses = models.Select(m => (m.Id, "", false)).ToList();
        StateHasChanged();

        var systemPrompt = $"You are a creative writing assistant. Write in the style of a {CreativeStyle}. Be imaginative and engaging.";
        var apiMessages  = new[] {
            new ApiChatMessage { Role = "system", Content = systemPrompt },
            new ApiChatMessage { Role = "user",   Content = prompt },
        };

        var tasks = models.Select(async (model, idx) =>
        {
            var apiResult = await AiApi.ChatAsync(model.Id, apiMessages);
            var text = apiResult is { Status: "done" }
                ? apiResult.Text
                : $"{prompt}\n\n{ModelCatalogue.DemoResponses[idx % ModelCatalogue.DemoResponses.Length]}";
            CreativeResponses[idx] = (model.Id, text, true);
            await InvokeAsync(StateHasChanged);
        });
        await Task.WhenAll(tasks);
    }

