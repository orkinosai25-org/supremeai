                ImageGenStatus = "error";
                ImageResult = "<div style='text-align:center;padding:1rem;color:var(--sai-text-muted)'>Could not render image. Please try again.</div>";
            }
        }
        catch
        {
            ImageGenStatus = "error";
            ImageResult = "<div style='text-align:center;padding:1rem;color:var(--sai-text-muted)'>Could not render image. Please try again.</div>";
        }

        await InvokeAsync(StateHasChanged);
    }

