    private static string ModelInitial(string modelId, AiModel? model) =>
        model?.Initial ?? modelId[..Math.Min(2, modelId.Length)].ToUpper();

    private static ApiSupremeResponse BuildDemoSupremeResult(string query)
    {
        var rng = new Random();
        var demoIds = new[] { "gpt-4o", "llama-3-1-70b", "mistral-large" };
        var results = demoIds.Select((id, i) =>
        {
            var latency  = 800 + rng.Next(0, 2200);
            var text     = ModelCatalogue.DemoResponses[i % ModelCatalogue.DemoResponses.Length];
            double score = Math.Round(4.5 + rng.NextDouble() * 5, 2);
            return new ApiModelEvalResult
            {
                ModelId = id,
                Text    = text,
                Status  = "done",
                Tokens  = 120 + rng.Next(0, 300),
                Ms      = latency,
                Score   = score,
            };
        })
        .OrderByDescending(r => r.Score)
        .ToList();

        var winner = results[0];
        return new ApiSupremeResponse
        {
            Query         = query,
            Results       = results,
            WinnerId      = winner.ModelId,
            SupremeAnswer = winner.Text,
            TotalMs       = results.Max(r => r.Ms),
        };
    }

    private async void SubmitChatPrompt()
    {
        if (!CanSend) return;
        var prompt = ChatPrompt.Trim();
        ChatPrompt = "";

        if (SupremeMode)
        {
            // SupremeAI mode: route through supreme evaluation
            var placeholderResp = new ModelResponse { ModelId = "supreme", Status = "loading" };
            var conv = new Conversation { Prompt = prompt, Responses = [placeholderResp] };
            Conversations.Add(conv);
            ConvSupremeResults.Add(null);
            StateHasChanged();

            ApiSupremeResponse supremeResult;
            var modelIds = SelectedIds.Count > 0 ? SelectedIds : null;
            var apiResponse = await AiApi.SupremeAsync(prompt, modelIds);
            supremeResult = (apiResponse is { SupremeAnswer.Length: > 0 })
                ? apiResponse
                : BuildDemoSupremeResult(prompt);

            var winnerModel = ModelCatalogue.ChatModels.FirstOrDefault(m => m.Id == supremeResult.WinnerId);
            conv.Responses[0] = new ModelResponse
            {
                ModelId = supremeResult.WinnerId,
                Text    = supremeResult.SupremeAnswer,
                Status  = "done",
                Tokens  = supremeResult.Results.FirstOrDefault(r => r.ModelId == supremeResult.WinnerId)?.Tokens ?? 0,
                Ms      = supremeResult.TotalMs,
            };
            ConvSupremeResults[^1] = supremeResult;
            await InvokeAsync(StateHasChanged);
            return;
        }

        // Direct mode: fan-out to selected models (existing behaviour)
        var selectedModels = ModelCatalogue.ChatModels.Where(m => SelectedIds.Contains(m.Id)).ToList();
        var directConv = new Conversation { Prompt = prompt, Responses = selectedModels.Select(m => new ModelResponse { ModelId = m.Id }).ToList() };
        Conversations.Add(directConv);
        ConvSupremeResults.Add(null);
        StateHasChanged();

        var apiMessages = new[] { new ApiChatMessage { Role = "user", Content = prompt } };

        var tasks = selectedModels.Select(async (model, idx) =>
        {
            var resp = directConv.Responses.First(r => r.ModelId == model.Id);
            var startMs = Environment.TickCount;

            var apiResult = await AiApi.ChatAsync(model.Id, apiMessages);

            if (apiResult is not null)
            {
                var text = apiResult.Status == "error"
                    ? $"[Error from {model.Name}: {apiResult.ErrorMessage}]"
                    : apiResult.Text;

                var totalChars = text.Length;
                var chunkSize = Math.Max(1, totalChars / 60);
                var charIndex = 0;
                while (charIndex < totalChars)
                {
                    charIndex = Math.Min(charIndex + chunkSize, totalChars);
                    resp.Text = text[..charIndex];
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(25);
                }
                resp.Status = apiResult.Status == "error" ? "error" : "done";
                resp.Tokens = apiResult.Tokens;
                resp.Ms     = apiResult.Ms > 0 ? apiResult.Ms : Environment.TickCount - startMs;
            }
            else
            {
                await Task.Delay(idx * 220 + Random.Shared.Next(300));
                var demoText = ModelCatalogue.DemoResponses[idx % ModelCatalogue.DemoResponses.Length];
                var totalChars = demoText.Length;
                var chunkSize = Math.Max(1, totalChars / 60);
                var charIndex = 0;
                while (charIndex < totalChars)
                {
                    charIndex = Math.Min(charIndex + chunkSize, totalChars);
                    resp.Text = demoText[..charIndex];
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(50);
                }
                resp.Status = "done";
                resp.Tokens = totalChars / 4;
                resp.Ms = Environment.TickCount - startMs;
            }

            await InvokeAsync(StateHasChanged);
        });
        await Task.WhenAll(tasks);
    }

    private async void SubmitImagePrompt()
    {
        if (string.IsNullOrWhiteSpace(ImagePrompt)) return;
        var prompt = ImagePrompt.Trim();
        ImageGenStatus = "loading";
        ImageDownloadUrl = "";
        ImageResult = "<div style='text-align:center;padding:1rem'><span class='sai-skeleton' style='display:block;width:100%;height:180px;border-radius:10px'></span><p style='margin-top:0.75rem;font-size:0.85rem;color:var(--sai-text-muted)'>Generating image…</p></div>";
        ImagePrompt = "";
        StateHasChanged();

        try
        {
            var imageUrl = await JS.InvokeAsync<string>("saiRenderGrooveMakerImage", new
            {
                text = prompt,
                platform = ImagePlatform,
                backgroundCategory = ImageBackgroundCategory,
                overlay = ImageOverlay,
                frame = ImageFrame,
            });

            if (!string.IsNullOrWhiteSpace(imageUrl))
            {
                ImageGenStatus = "done";
                ImageDownloadUrl = imageUrl;
                ImageResult = $"<div style='text-align:center;padding:1rem'><img src='{imageUrl}' alt='GrooveMaker generated image' style='max-width:100%;border-radius:10px' /></div>";
