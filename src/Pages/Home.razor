    private async Task CopyText(string text)
    {
        if (!string.IsNullOrEmpty(text))
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private async Task DownloadText(string text, string filename)
    {
        if (!string.IsNullOrEmpty(text))
            await JS.InvokeVoidAsync("saiDownloadText", filename, text);
    }

    private async Task DownloadCode(string code, string modelId)
    {
        if (string.IsNullOrEmpty(code)) return;
        var ext = CodeLang switch
        {
            "python"     => "py",
            "typescript" => "ts",
            "javascript" => "js",
            "rust"       => "rs",
            "go"         => "go",
            "java"       => "java",
            "csharp"     => "cs",
            "sql"        => "sql",
            _            => "txt",
        };
        var safeName = System.Text.RegularExpressions.Regex.Replace(modelId, @"[^a-z0-9\-]", "-");
        await JS.InvokeVoidAsync("saiDownloadText", $"code-{safeName}.{ext}", code);
    }

    private async Task DownloadImage()
    {
        if (!string.IsNullOrEmpty(ImageDownloadUrl))
            await JS.InvokeVoidAsync("saiDownloadUrl", ImageDownloadUrl, $"groovemaker-{ImagePlatform}.png");
    }

    private async Task DownloadVideo()
    {
        if (!string.IsNullOrEmpty(VideoDownloadUrl))
            await JS.InvokeVoidAsync("saiDownloadUrl", VideoDownloadUrl, "generated-video.mp4");
    }

    private static string EscHtml(string s) =>
        s.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;").Replace("\"", "&quot;");
