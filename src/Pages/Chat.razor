@page "/chat"
@using SupremeAI.Models
@using SupremeAI.Services
@inject AiApiService AiApi
@inject IJSRuntime JS
@inject ILogger<Chat> Logger

<PageTitle>Supreme Model T‑X Chat</PageTitle>

<div class="chat-shell">

    <!-- ─── Header ─── -->
    <header class="chat-header">
        <div class="chat-header-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
        </div>
        <div>
            <h1 class="chat-title">Supreme Model T‑X Chat</h1>
            <p class="chat-subtitle">Direct conversation with any AI model. Select a model and start chatting.</p>
        </div>
    </header>

    <!-- ─── Model selector ─── -->
    <section class="chat-model-section">
        <label class="chat-section-label" for="chat-model-select">Model</label>
        <div class="chat-model-row">
            <select id="chat-model-select" class="chat-model-select" @bind="_selectedModelId" disabled="@_isRunning">
                @foreach (var model in ModelCatalogue.ChatModels.Where(m => !m.ComingSoon))
                {
                    <option value="@model.Id">@model.Name — @model.Provider</option>
                }
            </select>
            @{
                var selectedMeta = ModelCatalogue.ChatModels.FirstOrDefault(m => m.Id == _selectedModelId);
            }
            @if (selectedMeta is not null)
            {
                <span class="chat-model-badge" style="background:@selectedMeta.Color">
                    @selectedMeta.Initial
                </span>
            }
        </div>
    </section>

    <!-- ─── Conversation ─── -->
    <section class="chat-conversation" aria-label="Conversation" @ref="_conversationRef">
        @if (_messages.Count == 0)
        {
            <div class="chat-empty-state">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3" aria-hidden="true">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                <p>No messages yet. Type below to begin.</p>
            </div>
        }
        @foreach (var msg in _messages)
        {
            <div class="chat-message @(msg.IsUser ? "user" : "assistant")">
                @if (!msg.IsUser)
                {
                    <div class="chat-msg-badge" style="background:@(ModelCatalogue.ChatModels.FirstOrDefault(m => m.Id == msg.ModelId)?.Color ?? "#555")">
                        @(ModelCatalogue.ChatModels.FirstOrDefault(m => m.Id == msg.ModelId)?.Initial ?? "AI")
                    </div>
                }
                <div class="chat-msg-bubble">
                    @if (msg.IsError)
                    {
                        <span class="chat-msg-error">@msg.Content</span>
                    }
                    else
                    {
                        <span class="chat-msg-text">@msg.Content</span>
                    }
                    @if (!msg.IsUser && msg.Ms > 0)
                    {
                        <span class="chat-msg-meta">@msg.Ms ms@(msg.Tokens > 0 ? $" · {msg.Tokens} tok" : "")</span>
                    }
                </div>
                @if (msg.IsUser)
                {
                    <div class="chat-msg-avatar">You</div>
                }
            </div>
        }
        @if (_isRunning)
        {
            <div class="chat-message assistant">
                <div class="chat-msg-badge" style="background:@(selectedMeta?.Color ?? "#555")">
                    @(selectedMeta?.Initial ?? "AI")
                </div>
                <div class="chat-msg-bubble">
                    <span class="chat-typing">
                        <span></span><span></span><span></span>
                    </span>
                </div>
            </div>
        }
    </section>

    <!-- ─── Error banner ─── -->
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="chat-error" role="alert">
            <strong>Error:</strong>
            <pre class="chat-error-detail">@_errorMessage</pre>
        </div>
    }

    <!-- ─── Input bar ─── -->
    <div class="chat-input-bar">
        <textarea class="chat-input"
                  placeholder="Type a message…"
                  rows="1"
                  @bind="_inputText"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  disabled="@_isRunning"
                  aria-label="Chat input" />
        <button class="chat-send-btn"
                @onclick="SendMessage"
                disabled="@(_isRunning || string.IsNullOrWhiteSpace(_inputText))"
                title="Send message (Enter)">
            @if (_isRunning)
            {
                <span class="chat-send-spinner" aria-hidden="true"></span>
            }
            else
            {
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
            }
        </button>
        <button class="chat-clear-btn"
                @onclick="ClearConversation"
                disabled="@(_isRunning || _messages.Count == 0)"
                title="Clear conversation">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
            </svg>
        </button>
    </div>

    <!-- ─── Backend unavailable warning ─── -->
    @if (_backendUnavailable)
    {
        <div class="chat-config-warning" role="alert">
            <strong>⚠ Backend API unavailable.</strong>
            The SupremeAI API could not be reached. Real AI responses are disabled.
            <br />
            To enable real inference, configure the following environment variables in your deployment
            (Azure App Service → Configuration, or a <code>.env</code> file for local development):
            <ul>
                <li><code>AZURE_OPENAI_ENDPOINT</code> + <code>AZURE_OPENAI_API_KEY</code> — GPT-4o, o1-preview, DALL-E 3</li>
                <li><code>ANTHROPIC_API_KEY</code> — Claude 3.5 Sonnet</li>
                <li><code>GOOGLE_GEMINI_API_KEY</code> — Gemini 1.5 Pro</li>
                <li><code>XAI_GROK_API_KEY</code> — Grok-2</li>
                <li><code>LLAMA_31_70B_ENDPOINT</code> + <code>LLAMA_31_70B_API_KEY</code> — Llama 3.1 70B (Azure AI Foundry)</li>
                <li><code>MISTRAL_LARGE_ENDPOINT</code> + <code>MISTRAL_LARGE_API_KEY</code> — Mistral Large (Azure AI Foundry)</li>
            </ul>
            See <code>.env.example</code> in the repository for the full list.
        </div>
    }

</div>

<style>
    /* ── Shell ────────────────────────────────────────────────────────────── */
    .chat-shell {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1.25rem 2rem;
        font-family: var(--sai-font, system-ui, sans-serif);
        color: var(--sai-fg, #e8e8e8);
        display: flex;
        flex-direction: column;
        gap: 1rem;
        min-height: calc(100vh - 4rem);
    }

    /* ── Header ──────────────────────────────────────────────────────────── */
    .chat-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.5rem;
    }
    .chat-header-icon { color: gold; flex-shrink: 0; }
    .chat-title { font-size: 1.75rem; font-weight: 700; margin: 0; }
    .chat-subtitle { font-size: 0.875rem; color: #aaa; margin: 0.2rem 0 0; }

    /* ── Model selector ──────────────────────────────────────────────────── */
    .chat-model-section { }
    .chat-section-label {
        display: block;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #888;
        margin-bottom: 0.5rem;
    }
    .chat-model-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }
    .chat-model-select {
        flex: 1;
        background: #1a1a1a;
        border: 1.5px solid #333;
        border-radius: 8px;
        color: #e8e8e8;
        font-size: 0.9rem;
        padding: 0.45rem 0.75rem;
        cursor: pointer;
        transition: border-color 0.15s;
    }
    .chat-model-select:focus { outline: none; border-color: gold; }
    .chat-model-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px; height: 32px;
        border-radius: 50%;
        font-size: 0.65rem;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
    }

    /* ── Conversation ────────────────────────────────────────────────────── */
    .chat-conversation {
        flex: 1;
        background: #111;
        border: 1.5px solid #222;
        border-radius: 12px;
        padding: 1rem;
        min-height: 320px;
        max-height: 520px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        scroll-behavior: smooth;
    }
    .chat-empty-state {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #444;
        text-align: center;
        gap: 0.5rem;
        font-size: 0.85rem;
    }

    /* ── Messages ────────────────────────────────────────────────────────── */
    .chat-message {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }
    .chat-message.user { flex-direction: row-reverse; }
    .chat-msg-badge {
        width: 30px; height: 30px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.62rem; font-weight: 700; color: #fff;
        flex-shrink: 0;
    }
    .chat-msg-avatar {
        width: 30px; height: 30px;
        border-radius: 50%;
        background: #2a2a2a;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.6rem; color: #888;
        flex-shrink: 0;
    }
    .chat-msg-bubble {
        max-width: 78%;
        background: #1c1c1c;
        border-radius: 12px;
        padding: 0.6rem 0.9rem;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }
    .chat-message.user .chat-msg-bubble {
        background: #1a1a0a;
        border: 1px solid #333300;
    }
    .chat-msg-text {
        font-size: 0.875rem;
        line-height: 1.6;
        white-space: pre-wrap;
        color: #e0e0e0;
    }
    .chat-msg-error { color: #f66; font-size: 0.875rem; }
    .chat-msg-meta { font-size: 0.7rem; color: #555; }

    /* ── Typing indicator ────────────────────────────────────────────────── */
    .chat-typing {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 0.1rem 0;
    }
    .chat-typing span {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: #888;
        animation: chatBounce 1.2s ease-in-out infinite;
    }
    .chat-typing span:nth-child(1) { animation-delay: 0s; }
    .chat-typing span:nth-child(2) { animation-delay: 0.2s; }
    .chat-typing span:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes chatBounce {
        0%, 80%, 100% { transform: scale(1); opacity: 0.5; }
        40%            { transform: scale(1.3); opacity: 1; }
    }

    /* ── Error banner ────────────────────────────────────────────────────── */
    .chat-error {
        background: #3a1515;
        border: 1px solid #a33;
        border-radius: 8px;
        padding: 0.6rem 0.9rem;
        font-size: 0.875rem;
        color: #f88;
    }
    .chat-error-detail {
        margin: 0.5rem 0 0;
        font-size: 0.75rem;
        line-height: 1.5;
        white-space: pre-wrap;
        overflow-wrap: break-word;
        overflow: auto;
        max-height: 40vh;
        background: #2a0a0a;
        border-radius: 5px;
        padding: 0.5rem 0.75rem;
        color: #f99;
    }

    /* ── Input bar ───────────────────────────────────────────────────────── */
    .chat-input-bar {
        display: flex;
        align-items: flex-end;
        gap: 0.5rem;
    }
    .chat-input {
        flex: 1;
        background: #1a1a1a;
        border: 1.5px solid #333;
        border-radius: 10px;
        color: #e8e8e8;
        font-size: 0.95rem;
        padding: 0.65rem 1rem;
        resize: none;
        min-height: 42px;
        max-height: 160px;
        box-sizing: border-box;
        transition: border-color 0.15s;
        font-family: inherit;
    }
    .chat-input:focus { outline: none; border-color: gold; }
    .chat-send-btn, .chat-clear-btn {
        flex-shrink: 0;
        width: 42px; height: 42px;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.15s, background 0.15s;
    }
    .chat-send-btn {
        background: gold;
        color: #111;
    }
    .chat-send-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .chat-clear-btn {
        background: #2a2a2a;
        color: #888;
    }
    .chat-clear-btn:hover:not(:disabled) { background: #3a2020; color: #f88; }
    .chat-clear-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .chat-send-spinner {
        width: 16px; height: 16px;
        border: 2px solid #111;
        border-top-color: transparent;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        display: inline-block;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* ── Backend unavailable warning ─────────────────────────────────────── */
    .chat-config-warning {
        background: #2a1800;
        border: 1.5px solid #a05000;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        font-size: 0.85rem;
        color: #f0a050;
        line-height: 1.6;
    }
    .chat-config-warning strong { color: #ffc875; }
    .chat-config-warning code {
        background: #1a1000;
        border-radius: 4px;
        padding: 0.1rem 0.35rem;
        font-size: 0.78rem;
        color: #ffc875;
    }
    .chat-config-warning ul {
        margin: 0.4rem 0 0 1.2rem;
        padding: 0;
    }
    .chat-config-warning li { margin-bottom: 0.15rem; }
</style>

@code {
    private string _selectedModelId = ModelCatalogue.ChatModels
        .FirstOrDefault(m => !m.ComingSoon && m.DefaultSelected)?.Id
        ?? ModelCatalogue.ChatModels.First(m => !m.ComingSoon).Id;

    private string _inputText = "";
    private bool _isRunning;
    private bool _backendUnavailable;
    private string? _errorMessage;

    private readonly List<ChatEntry> _messages = [];

    private ElementReference _conversationRef;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !_isRunning && !string.IsNullOrWhiteSpace(_inputText))
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        var text = _inputText.Trim();
        if (string.IsNullOrWhiteSpace(text)) return;

        _inputText = "";
        _errorMessage = null;
        _isRunning = true;

        _messages.Add(new ChatEntry { IsUser = true, Content = text });
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            var history = _messages
                .Where(m => !m.IsError)
                .Select(m => new ApiChatMessage { Role = m.IsUser ? "user" : "assistant", Content = m.Content })
                .ToList();

            var response = await AiApi.ChatAsync(_selectedModelId, history);

            if (response is not null && response.Status != "error")
            {
                _backendUnavailable = false;
                _messages.Add(new ChatEntry
                {
                    IsUser  = false,
                    ModelId = response.ModelId,
                    Content = response.Text,
                    Tokens  = response.Tokens,
                    Ms      = response.Ms,
                });
            }
            else if (response is not null && response.Status == "error")
            {
                _messages.Add(new ChatEntry
                {
                    IsUser  = false,
                    ModelId = _selectedModelId,
                    Content = response.ErrorMessage ?? "An error occurred.",
                    IsError = true,
                });
            }
            else
            {
                // API is unreachable — show warning, do not fabricate a response.
                _backendUnavailable = true;
                _messages.Add(new ChatEntry
                {
                    IsUser  = false,
                    ModelId = _selectedModelId,
                    Content = "⚠ The backend API is unavailable. Configure your API keys and redeploy. See the warning below for details.",
                    IsError = true,
                });
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error during chat");
            _errorMessage = ex.Message;
        }
        finally
        {
            _isRunning = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private void ClearConversation()
    {
        _messages.Clear();
        _errorMessage = null;
        _backendUnavailable = false;
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "document.querySelector('.chat-conversation')?.scrollTo({top:9999,behavior:'smooth'})");
        }
        catch { /* JS interop may fail during pre-render */ }
    }

    private sealed class ChatEntry
    {
        public bool   IsUser  { get; init; }
        public string ModelId { get; set; } = "";
        public string Content { get; set; } = "";
        public bool   IsError { get; init; }
        public int    Tokens  { get; init; }
        public int    Ms      { get; init; }
    }
}
