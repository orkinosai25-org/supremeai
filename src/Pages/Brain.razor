@page "/brain"
@using SupremeAI.Models
@using SupremeAI.Services
@inject AiApiService AiApi
@inject IJSRuntime JS

<PageTitle>SupremeAI Brain</PageTitle>

<div class="brain-shell">

    <!-- ─── Header ─── -->
    <header class="brain-header">
        <div class="brain-crown" aria-hidden="true">
            <svg viewBox="0 0 36 28" xmlns="http://www.w3.org/2000/svg" width="36" height="28">
                <polygon points="18,2 34,22 26,18 18,26 10,18 2,22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/>
            </svg>
        </div>
        <div>
            <h1 class="brain-title">SupremeAI Brain</h1>
            <p class="brain-subtitle">The meta-intelligence layer — evaluates, scores and selects the best answer across all AI models.</p>
        </div>
    </header>

    <!-- ─── Model selector ─── -->
    <section class="brain-models-section">
        <h2 class="brain-section-title">Select models to benchmark</h2>
        <div class="brain-model-grid">
            @foreach (var model in ModelCatalogue.ChatModels.Where(m => !m.ComingSoon))
            {
                var selected = _selectedModels.Contains(model.Id);
                <button class="brain-model-chip @(selected ? "selected" : "")"
                        style="@(selected ? $"border-color:{model.Color};color:{model.Color}" : "")"
                        @onclick="() => ToggleModel(model.Id)"
                        title="@model.Provider">
                    <span class="chip-initial" style="background:@model.Color">@model.Initial</span>
                    <span class="chip-name">@model.Name</span>
                </button>
            }
        </div>
        <p class="brain-model-hint">
            @(_selectedModels.Count == 0
                ? "No models selected — default panel (GPT-4o · Llama 3.1 70B · Mistral Large) will be used."
                : $"{_selectedModels.Count} model(s) selected.")
        </p>
    </section>

    <!-- ─── Query input ─── -->
    <section class="brain-query-section">
        <label for="brain-query" class="brain-section-title">Your prompt</label>
        <textarea id="brain-query"
                  class="brain-query-input"
                  placeholder="Ask anything… SupremeAI will evaluate every model and choose the best answer."
                  rows="4"
                  @bind="_query"
                  @bind:event="oninput"
                  disabled="@_isRunning" />
        <button class="brain-run-btn"
                @onclick="RunSupreme"
                disabled="@(_isRunning || string.IsNullOrWhiteSpace(_query))">
            @if (_isRunning)
            {
                <span class="brain-spinner" aria-hidden="true"></span>
                <span>Evaluating…</span>
            }
            else
            {
                <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" width="18" height="18" aria-hidden="true">
                    <polygon points="4,2 18,10 4,18" fill="currentColor"/>
                </svg>
                <span>Run Supreme Evaluation</span>
            }
        </button>
    </section>

    <!-- ─── Error banner ─── -->
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="brain-error" role="alert">
            <strong>Error:</strong> @_errorMessage
        </div>
    }

    <!-- ─── Results ─── -->
    @if (_result is not null)
    {
        <!-- Supreme Answer -->
        <section class="brain-supreme-section">
            <div class="brain-supreme-badge">
                <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" width="16" height="16" aria-hidden="true">
                    <polygon points="10,1 12.9,7 19.5,7.6 14.75,11.8 16.2,18.4 10,14.9 3.8,18.4 5.25,11.8 0.5,7.6 7.1,7" fill="currentColor"/>
                </svg>
                Supreme Answer
            </div>
            <div class="brain-winner-label">
                Winner: <strong>@WinnerName</strong>
                <span class="brain-meta">· @_result.TotalMs ms total</span>
            </div>
            <div class="brain-supreme-answer">@_result.SupremeAnswer</div>
        </section>

        <!-- Per-model results -->
        <section class="brain-results-section">
            <h2 class="brain-section-title">Model comparison</h2>
            <div class="brain-results-grid">
                @foreach (var r in _result.Results)
                {
                    var modelMeta = ModelCatalogue.ChatModels.FirstOrDefault(m => m.Id == r.ModelId);
                    var color     = modelMeta?.Color ?? "#888";
                    var isWinner  = r.ModelId == _result.WinnerId;
                    <div class="brain-result-card @(isWinner ? "winner" : "") @(r.Status == "error" ? "errored" : "")"
                         style="@(isWinner ? $"border-color:{color}" : "")">
                        <div class="result-header">
                            <div class="result-initial" style="background:@color">
                                @(modelMeta?.Initial ?? r.ModelId[..Math.Min(2, r.ModelId.Length)].ToUpper())
                            </div>
                            <div class="result-name">
                                <span class="result-model-name">@(modelMeta?.Name ?? r.ModelId)</span>
                                <span class="result-provider">@(modelMeta?.Provider ?? "")</span>
                            </div>
                            @if (isWinner)
                            {
                                <span class="result-winner-crown" title="Winner" style="color:@color">★</span>
                            }
                        </div>
                        <div class="result-score-row">
                            <div class="result-score-bar-wrap">
                                <div class="result-score-bar" style="width:@(r.Score * 10)%;background:@color"></div>
                            </div>
                            <span class="result-score-value">@r.Score.ToString("F1")</span>
                        </div>
                        <div class="result-meta">
                            <span>@r.Ms ms</span>
                            @if (r.Tokens > 0) { <span>· @r.Tokens tok</span> }
                        </div>
                        <div class="result-text">
                            @if (r.Status == "error")
                            {
                                <span class="result-error">@r.ErrorMessage</span>
                            }
                            else
                            {
                                @r.Text
                            }
                        </div>
                    </div>
                }
            </div>
        </section>
    }

</div>

<!-- ─── Demo mode banner ─── -->
@if (_demoMode && _result is not null)
{
    <div class="brain-demo-banner">
        Demo mode — backend API unavailable. Showing simulated evaluation results.
    </div>
}

<style>
    /* ── Shell ───────────────────────────────────────────────────────────── */
    .brain-shell {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
        font-family: var(--sai-font, system-ui, sans-serif);
        color: var(--sai-fg, #e8e8e8);
    }

    /* ── Header ─────────────────────────────────────────────────────────── */
    .brain-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .brain-crown { color: gold; flex-shrink: 0; }
    .brain-title { font-size: 1.75rem; font-weight: 700; margin: 0; }
    .brain-subtitle { font-size: 0.875rem; color: #aaa; margin: 0.2rem 0 0; }

    /* ── Section titles ──────────────────────────────────────────────────── */
    .brain-section-title {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #888;
        margin: 0 0 0.75rem;
        display: block;
    }

    /* ── Model selector ──────────────────────────────────────────────────── */
    .brain-models-section { margin-bottom: 1.5rem; }
    .brain-model-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .brain-model-chip {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.3rem 0.75rem 0.3rem 0.35rem;
        border: 1.5px solid #444;
        border-radius: 999px;
        background: transparent;
        color: #ccc;
        cursor: pointer;
        font-size: 0.8rem;
        transition: border-color 0.15s, color 0.15s;
    }
    .brain-model-chip:hover { border-color: #888; }
    .brain-model-chip.selected { font-weight: 600; }
    .chip-initial {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px; height: 22px;
        border-radius: 50%;
        font-size: 0.65rem;
        font-weight: 700;
        color: #fff;
    }
    .brain-model-hint { font-size: 0.75rem; color: #666; margin: 0.5rem 0 0; }

    /* ── Query input ─────────────────────────────────────────────────────── */
    .brain-query-section { margin-bottom: 1.5rem; }
    .brain-query-input {
        width: 100%;
        background: #1a1a1a;
        border: 1.5px solid #333;
        border-radius: 10px;
        color: #e8e8e8;
        font-size: 0.95rem;
        padding: 0.75rem 1rem;
        resize: vertical;
        box-sizing: border-box;
        transition: border-color 0.15s;
    }
    .brain-query-input:focus { outline: none; border-color: gold; }
    .brain-run-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        margin-top: 0.75rem;
        padding: 0.55rem 1.4rem;
        background: gold;
        color: #111;
        border: none;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.15s;
    }
    .brain-run-btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .brain-spinner {
        width: 16px; height: 16px;
        border: 2px solid #111;
        border-top-color: transparent;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        display: inline-block;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* ── Error banner ────────────────────────────────────────────────────── */
    .brain-error {
        background: #3a1515;
        border: 1px solid #a33;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
        color: #f88;
    }

    /* ── Supreme answer ──────────────────────────────────────────────────── */
    .brain-supreme-section {
        background: linear-gradient(135deg, #1a1a00 0%, #1a1500 100%);
        border: 1.5px solid gold;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 2rem;
    }
    .brain-supreme-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: gold;
        color: #111;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
        margin-bottom: 0.5rem;
    }
    .brain-winner-label {
        font-size: 0.85rem;
        color: #aaa;
        margin-bottom: 0.75rem;
    }
    .brain-winner-label strong { color: gold; }
    .brain-meta { font-size: 0.8rem; color: #666; }
    .brain-supreme-answer {
        font-size: 0.95rem;
        line-height: 1.65;
        white-space: pre-wrap;
        color: #e8e8e8;
    }

    /* ── Per-model results ───────────────────────────────────────────────── */
    .brain-results-section { margin-bottom: 2rem; }
    .brain-results-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1rem;
    }
    .brain-result-card {
        background: #141414;
        border: 1.5px solid #2a2a2a;
        border-radius: 12px;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }
    .brain-result-card.winner { background: #141400; }
    .brain-result-card.errored { opacity: 0.6; }
    .result-header { display: flex; align-items: center; gap: 0.6rem; }
    .result-initial {
        width: 32px; height: 32px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.7rem; font-weight: 700; color: #fff;
        flex-shrink: 0;
    }
    .result-name { flex: 1; min-width: 0; }
    .result-model-name { display: block; font-size: 0.85rem; font-weight: 600; }
    .result-provider { font-size: 0.72rem; color: #666; }
    .result-winner-crown { font-size: 1.1rem; }
    .result-score-row { display: flex; align-items: center; gap: 0.5rem; }
    .result-score-bar-wrap {
        flex: 1; height: 6px; background: #222; border-radius: 999px; overflow: hidden;
    }
    .result-score-bar { height: 100%; border-radius: 999px; transition: width 0.4s ease; }
    .result-score-value { font-size: 0.8rem; font-weight: 700; min-width: 28px; text-align: right; }
    .result-meta { font-size: 0.72rem; color: #555; }
    .result-text {
        font-size: 0.8rem;
        line-height: 1.55;
        color: #bbb;
        white-space: pre-wrap;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 8;
        -webkit-box-orient: vertical;
    }
    .result-error { color: #f66; }

    /* ── Demo banner ─────────────────────────────────────────────────────── */
    .brain-demo-banner {
        position: fixed;
        bottom: 1rem; left: 50%;
        transform: translateX(-50%);
        background: #222;
        border: 1px solid #444;
        border-radius: 999px;
        padding: 0.4rem 1.25rem;
        font-size: 0.75rem;
        color: #888;
        white-space: nowrap;
    }
</style>

@code {
    private string _query = "";
    private bool _isRunning;
    private bool _demoMode;
    private string? _errorMessage;
    private ApiSupremeResponse? _result;

    private readonly HashSet<string> _selectedModels = [];

    private string WinnerName =>
        ModelCatalogue.ChatModels
            .FirstOrDefault(m => m.Id == _result?.WinnerId)?.Name
        ?? _result?.WinnerId
        ?? "";

    private void ToggleModel(string modelId)
    {
        if (!_selectedModels.Remove(modelId))
            _selectedModels.Add(modelId);
    }

    private async Task RunSupreme()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;

        _isRunning = true;
        _errorMessage = null;
        _result = null;
        StateHasChanged();

        try
        {
            var modelIds = _selectedModels.Count > 0
                ? (IEnumerable<string>)_selectedModels
                : null;

            var response = await AiApi.SupremeAsync(_query, modelIds);

            if (response is not null)
            {
                _result = response;
                _demoMode = false;
            }
            else
            {
                _result = BuildDemoResult(_query);
                _demoMode = true;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    // ── Demo / fallback ────────────────────────────────────────────────────

    private static readonly string[] DemoModelIds = ["gpt-4o", "llama-3-1-70b", "mistral-large"];

    private static ApiSupremeResponse BuildDemoResult(string query)
    {
        var rng = new Random();
        var results = DemoModelIds.Select((id, i) =>
        {
            var latency  = 800 + rng.Next(0, 2200);
            var text     = ModelCatalogue.DemoResponses[i % ModelCatalogue.DemoResponses.Length];
            double score = Math.Round(4.5 + rng.NextDouble() * 5, 2);
            return new ApiModelEvalResult
            {
                ModelId = id,
                Text    = text,
                Status  = "done",
                Tokens  = 120 + rng.Next(0, 300),
                Ms      = latency,
                Score   = score,
            };
        })
        .OrderByDescending(r => r.Score)
        .ToList();

        var winner = results[0];
        return new ApiSupremeResponse
        {
            Query         = query,
            Results       = results,
            WinnerId      = winner.ModelId,
            SupremeAnswer = winner.Text,
            TotalMs       = results.Max(r => r.Ms),
        };
    }
}
